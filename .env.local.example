NEXT_PUBLIC_BASE_URL=http://localhost:3000
DB_PATH=./data/links.db

# Auth.js – Pflicht in Production, optional lokal (Default-Secret beim Dev).
# Erzeugen mit: openssl rand -hex 32
AUTH_SECRET=

# Hinter Reverse Proxy (z.B. Sliplane/Caddy) auf true setzen.
AUTH_TRUST_HOST=true

# Production-URL (Auth.js v5). Lokal nicht nötig.
# AUTH_URL=https://listate.de

# Google OAuth (aus Google Cloud Console: APIs & Services → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Komma-getrennte Liste der Super-Admins. Beim Login wird die Rolle gesetzt.
SUPER_ADMIN_EMAILS=schneider@upandfine.de

# Google Safe Browsing (optional, empfohlen).
# API-Key holen: https://console.cloud.google.com → APIs & Services →
# „Safe Browsing API" aktivieren → API-Key erstellen. Free Tier reicht
# für ~10.000 Lookups/Tag. Wenn leer, wird die Prüfung übersprungen.
GOOGLE_SAFE_BROWSING_API_KEY=

# Dev-Bypass-Login (NUR LOKAL, NIEMALS auf Sliplane/Production setzen!).
# Wenn auf 'true' und NODE_ENV != 'production', erscheint auf /login
# zusätzlich ein „Dev-Login"-Button, der ohne OAuth als
# 'dev@listate.local' (Rolle: admin) anmeldet. Greift nicht in Production,
# selbst wenn die Variable versehentlich gesetzt würde – durch doppelte
# Bedingung in auth.ts.
DEV_AUTH_BYPASS=true
